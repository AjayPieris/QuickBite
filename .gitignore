# =========================
# BACKEND (FastAPI / Python)
# =========================

# Virtual Environments
venv/
env/
.venv/

# Byte-compiled / Optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Environment Variables (CRITICAL: Never share your secrets!)
backend/.env
.env

# Database files (Just in case you use SQLite locally later)
*.sqlite3
*.db

# =========================
# FRONTEND (React / Vite)
# =========================

# Node Modules (Massive folder, let npm/yarn rebuild it)
node_modules/
frontend/node_modules/

# Production build output
dist/
build/
frontend/dist/

# Local Environment Variables
frontend/.env.local
frontend/.env.*.local

# npm/yarn/pnpm debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# =========================
# OS & EDITOR FILES
# =========================

# Mac
.DS_Store

# Windows
Thumbs.db

# VS Code / PyCharm / IDEs
.vscode/
.idea/
*.swp